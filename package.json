{
  "name": "esame-di-stato-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron.cjs",
  "build": {
    "appId": "com.examorchestrator.app",
    "productName": "Esame di Stato AI",
    "win": {
      "target": "dir"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "scripts": {
    "dev": "tsx backend/server.ts",
    "build": "vite build && node build-backend.js",
    "build:exe": "npm run build && electron-builder --win",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
